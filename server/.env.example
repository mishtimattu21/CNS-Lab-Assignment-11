# Optional: you can put these in the project root .env instead (server loads root .env first).
# URL can come from VITE_SUPABASE_URL in the root .env.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# TLS key and certificate for HTTPS + WSS (see README.md)
SSL_KEY_PATH=./certs/server.key
SSL_CERT_PATH=./certs/server.crt

PORT=3001
